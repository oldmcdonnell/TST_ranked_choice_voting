# Copy to .env and fill in for real deployment
PORT=8787
DB_PATH=./data/tstky.sqlite

# Set to a long random string in production
SESSION_SECRET=change-me-dev-only

# Where the frontend is hosted, for CORS + links in emails
FRONTEND_URL=http://localhost:5173

# Email sending (stubbed to console.log in dev — wire up a real
# provider, e.g. Resend/Postmark, before go-live)
MAIL_FROM=no-reply@tstky.example

# WebAuthn / FIDO2 admin login (fill in once you have a real domain)
RP_NAME=TST Kentucky Admin
RP_ID=localhost
ORIGIN=http://localhost:5173
